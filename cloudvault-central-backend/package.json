{
  "name": "cloudvault-central-backend",
  "version": "0.1.0",
  "description": "Backend for CloudVault Central (Express + AWS SDK v3 + Azure SDK)",
  "main": "server.js",
  "scripts": {
    "build": "npm --prefix ../cloudvault-central-frontend install && npm --prefix ../cloudvault-central-frontend run build",
    "build:frontend": "npm --prefix ../cloudvault-central-frontend run build",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test:integration": "node scripts/test_integration.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@aws-sdk/client-eventbridge": "^3.0.0",
    "@aws-sdk/client-iam": "^3.999.0",
    "@aws-sdk/client-secrets-manager": "^3.0.0",
    "@aws-sdk/client-sns": "^3.0.0",
    "@azure/identity": "^3.0.0",
    "@azure/keyvault-secrets": "^4.5.0",
    "@google-cloud/secret-manager": "^5.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "nodemailer": "^8.0.1"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  }
}
