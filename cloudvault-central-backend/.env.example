AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
IAM_SYNC_TTL_SECONDS=30

AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_KEY_VAULT_URL=

JWT_SECRET=your_jwt_secret_here
ALLOW_DEMO_LOGIN=true

ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_TO=security@example.com
ALERT_EMAIL_FROM=
ALERT_EMAIL_COOLDOWN_SECONDS=120
OWNER_EMAIL_DOMAIN=
ALERT_SNS_ENABLED=false
ALERT_SNS_TOPIC_ARN=
# For owner notifications, set one of these tags on each secret:
# ownerEmail, notifyEmail, email, owner_email, owner-mail, alertEmail
# For SNS owner notifications, add tag like:
# ownerSnsTopicArn=arn:aws:sns:ap-south-1:123456789012:owner-alert-topic

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
